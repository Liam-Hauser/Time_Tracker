# Copy this file to .env and fill in your PostgreSQL connection details.
# Either set DATABASE_URL directly, or set the individual vars below.

DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/time_tracker

# Alternative — used if DATABASE_URL is not set:
# DB_USER=user
# DB_PASSWORD=password
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=time_tracker
